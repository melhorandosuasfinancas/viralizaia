PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# OpenAI (Whisper + GPT-4)
OPENAI_API_KEY=sk-...

# Admin (para ativar usuários manualmente)
ADMIN_SECRET=seu_secret_admin_aqui

# Emails para teste (sempre retornam plano pro)
TEST_EMAILS=seuemail@exemplo.com

# ── APPMAX ───────────────────────────────────────────────────────────────────
# Token de segurança: Configure no painel APPMAX > Configurações > Webhook
# O token que você criar lá deve ser igual ao que está aqui
APPMAX_WEBHOOK_TOKEN=seu_token_webhook_appmax

# IDs dos produtos criados no painel APPMAX (Catálogo > Produtos)
# Copie o ID de cada produto e cole aqui
APPMAX_BASICO_ID=ID_DO_PRODUTO_BASICO
APPMAX_PRO_ID=ID_DO_PRODUTO_PRO
APPMAX_FULL_ID=ID_DO_PRODUTO_FULL
APPMAX_AGENCIA_ID=ID_DO_PRODUTO_AGENCIA

# URL do webhook para configurar no APPMAX:
# https://viralizaia.duckdns.org/api/auth/webhook/appmax
